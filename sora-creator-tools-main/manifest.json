{
  "manifest_version": 3,
  "name": "Sora Creator Tools – Sora Video Stats, Post Analytics, Views Tracker",
  "version": "2.0.0",
  "description": "Unofficial community overlays and analytics for Sora creators. Not affiliated with or endorsed by OpenAI.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["api.js", "uv-drafts-logic.js", "uv-drafts-page.js", "inject.js"],
      "matches": ["https://sora.chatgpt.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://sora.chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "host_permissions": ["https://sora.chatgpt.com/*"],
  "permissions": ["storage", "unlimitedStorage"],
  "background": {
    "service_worker": "background.js"
  }
}
